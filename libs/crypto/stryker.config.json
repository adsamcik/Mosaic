{
  "$schema": "https://raw.githubusercontent.com/stryker-mutator/stryker/master/packages/core/schema/stryker-schema.json",
  "packageManager": "npm",
  "testRunner": "vitest",
  "reporters": ["html", "clear-text", "progress"],
  "htmlReporter": {
    "fileName": "mutation-report/index.html"
  },
  "coverageAnalysis": "perTest",
  "mutate": [
    "src/**/*.ts",
    "!src/index.ts",
    "!src/mock.ts",
    "!src/argon2-params.ts",
    "!src/types.ts"
  ],
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  },
  "timeoutMS": 60000,
  "concurrency": 4,
  "disableTypeChecks": "src/**/*.ts",
  "vitest": {
    "configFile": "vitest.config.ts"
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "coverage",
    "mutation-report"
  ]
}
