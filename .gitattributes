# Auto detect text files and perform LF normalization
* text=auto eol=lf

# Explicitly declare text files
*.ts text
*.tsx text
*.js text
*.jsx text
*.json text
*.md text
*.html text
*.css text
*.scss text
*.yaml text
*.yml text
*.xml text
*.cs text
*.csproj text
*.sln text
*.sql text
*.sh text eol=lf
*.ps1 text eol=crlf

# Declare binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.webp binary
*.avif binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.wasm binary

# Diff settings
*.cs diff=csharp
*.sql diff=sql
*.md diff=markdown

# Linguist overrides
docs/* linguist-documentation
*.md linguist-documentation
