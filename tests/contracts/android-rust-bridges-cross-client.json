      "SYNC_PAGE_DID_NOT_ADVANCE": 703,
      "MANIFEST_OUTCOME_UNKNOWN": 704,
      "UNSUPPORTED_SNAPSHOT_VERSION": 705,
      "INVALID_SNAPSHOT": 706
    }
  },
  "manifestInvariants": {
    "comment": "Static AndroidManifest.xml invariants verified by apps/android-main/src/test/.../MergedManifestInvariantsTest.kt against the merged debug manifest produced by AGP.",
    "applicationAttributes": {
      "allowBackup": "false",
