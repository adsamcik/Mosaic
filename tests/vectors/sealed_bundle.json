{
  "schemaVersion": 1,
  "operation": "sharing.bundle.open.v1",
  "protocolVersion": "mosaic-v1",
  "rust_canonical": false,
  "description": "Verify-and-open of a sealed epoch key bundle. Sealing is non-deterministic; the open direction is byte-exact across clients (libsodium crypto_box_seal_open + Ed25519 verify).",
  "algorithms": {
    "seal": "crypto_box_seal (X25519 + XSalsa20-Poly1305 over ephemeral key)",
    "sign": "Ed25519 detached over (\"Mosaic_EpochBundle_v1\" || sealed)",
    "payload": "JSON: {version,albumId,epochId,recipientPubkey,epochSeed,signKeypair{pk,sk}} with base64url-no-pad fields"
  },
  "domainLabels": [
    "mosaic.v1.bundle.sign"
  ],
  "inputs": {
    "sealedHex": "",
    "signatureHex": "cb0bc1d1b9113d5f2726a965f3a255722cb1e4a4f96e51a750a903f96209b8000240f8ddde61cf394ed5665bc7d54f8a577832012a77b6af315a70655f735004",
    "sharerPubkeyHex": "d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a",
    "recipientIdentitySeedHex": "4ccd089b28ff96da9db6c346ec114e0f5b8a319f35aba624da8cf6ed4fb8a6fb",
    "expectedOwnerEd25519PubHex": "d75a980182b10ab7d54bfed3c964073a0ee172f3daa62325af021a68f707511a",
    "validation": {
      "albumId": "00000000-0000-7000-8000-000000000abc",
      "minEpochId": 0,
      "allowLegacyEmptyAlbumId": false
    }
  },
  "expected": {
    "bundleVersion": 1,
    "bundleAlbumId": "00000000-0000-7000-8000-000000000abc",
    "bundleEpochId": 66,
    "bundleRecipientPubkeyHex": "3d4017c3e843895a92b70aa74d1b7ebc9c982ccf2ec4968cc0cd55f12af4660c",
    "bundleEpochSeedHex": "cafe0102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e",
    "bundleSignPublicKeyHex": "fbcf900e65453f91e000e13e2bd9cf156381273e90f0c4b7ad70b97482f66534"
  },
  "negativeCases": [
    {
      "name": "wrong-owner-pubkey",
      "mutations": [
        "flip first byte of inputs.expectedOwnerEd25519PubHex"
      ],
      "errorCode": "BUNDLE_SIGNATURE_INVALID"
    },
    {
      "name": "tampered-signature",
      "mutations": [
        "flip first byte of inputs.signatureHex"
      ],
      "errorCode": "BUNDLE_SIGNATURE_INVALID"
    },
    {
      "name": "tampered-sealed",
      "mutations": [
        "flip first byte of inputs.sealedHex"
      ],
      "errorCode": "BUNDLE_SIGNATURE_INVALID"
    },
    {
      "name": "album-id-mismatch",
      "mutations": [
        "change inputs.validation.albumId to a different UUID"
      ],
      "errorCode": "BUNDLE_ALBUM_ID_MISMATCH"
    }
  ],
  "serverBoundOutputs": [
    {
      "name": "sealed",
      "classification": "encrypted",
      "reason": "Sealed bundle bytes are routed through the server to the recipient."
    },
    {
      "name": "signature",
      "classification": "public-cryptographic",
      "reason": "Detached Ed25519 signature is server-visible authenticity proof."
    },
    {
      "name": "sharerPubkey",
      "classification": "public-cryptographic",
      "reason": "Sharer identity public key is published as part of the bundle envelope."
    }
  ],
  "forbiddenServerOutputs": [
    {
      "name": "epochSeed",
      "reason": "Plaintext epoch seed grants tier-key derivation; only the sealed form is shared.",
      "errorCode": "PLAINTEXT_KEY_FORBIDDEN"
    },
    {
      "name": "signKeypairSecret",
      "reason": "Per-epoch manifest signing secret is bundled secretly; never plaintext server-side.",
      "errorCode": "PLAINTEXT_KEY_FORBIDDEN"
    }
  ]
}
