<?xml version="1.0" encoding="utf-8"?>
<!--
  apps/android-main AndroidManifest.

  Privacy / security invariants enforced here:
    - android:allowBackup="false" (no auto-backup of app-private storage).
    - android:hasFragileUserData="true" (caution-on-uninstall confirms encrypted data loss intent).
    - No INTERNET permission. This module does not contact a server.
    - No READ_EXTERNAL_STORAGE / MANAGE_EXTERNAL_STORAGE / READ_MEDIA_IMAGES.
      The Photo Picker integration is handled by future android-shell pieces; this v1
      slice is offline-only and only proves that the Rust core is wired.
    - Only one component is exported (the launcher activity, required by Android 12+).
    - android:requestLegacyExternalStorage is not declared (we never use it).

  Background-work invariants (Band 6 auto-import worker — see ADR-007):
    - FOREGROUND_SERVICE permission is declared so WorkManager can promote the
      auto-import worker to a user-visible foreground service during a
      long-running upload pass.
    - FOREGROUND_SERVICE_DATA_SYNC narrows that promotion to the `dataSync`
      service type that ADR-007 mandates for upload work; Android 14+ rejects
      promotions whose service type was not declared at install time.
    - POST_NOTIFICATIONS is declared because the user-visible notification
      driving the foreground promotion is a hard requirement on Android 13+.
    - UploadForegroundService is declared as a non-exported `dataSync`
      foreground service for user-cancellable shard upload notifications.
    - The merged WorkManager `SystemForegroundService` is patched with
      android:foregroundServiceType="dataSync" so the runtime `setForeground`
      call from `AutoImportWorker` matches the manifest declaration. The merge
      `tools:node="merge"` re-uses WorkManager's <service> entry instead of
      duplicating it.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

  <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
  <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />
  <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

  <application
      android:name=".MosaicApplication"
      android:allowBackup="false"
      android:hasFragileUserData="true"
      android:label="@string/app_name"
      android:icon="@mipmap/ic_launcher"
      android:roundIcon="@mipmap/ic_launcher_round"
      android:theme="@style/Theme.MosaicMain"
      android:supportsRtl="true">

    <activity
        android:name=".MainActivity"
        android:exported="true"
        android:label="@string/app_name"
        android:theme="@style/Theme.MosaicMain">
      <intent-filter>
        <action android:name="android.intent.action.MAIN" />
        <category android:name="android.intent.category.LAUNCHER" />
      </intent-filter>
    </activity>

    <service
        android:name="androidx.work.impl.foreground.SystemForegroundService"
        android:foregroundServiceType="dataSync"
        tools:node="merge" />

    <service
        android:name=".service.UploadForegroundService"
        android:exported="false"
        android:foregroundServiceType="dataSync" />

  </application>

</manifest>
