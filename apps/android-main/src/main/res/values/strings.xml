    Auto-import foreground notification strings. Kept deliberately generic so
    that the user-visible notification posted by AutoImportWorker never leaks
    album names, account identifiers, file paths, or any user-identifying
    material.
  -->
  <string name="auto_import_notification_channel_name">Mosaic auto-import</string>
  <string name="auto_import_notification_title">Mosaic auto-import</string>
  <string name="auto_import_notification_text">Encrypting and uploading queued items.</string>
  <!--
    Shard-pipeline foreground notification strings. Posted by
    ShardEncryptionWorker and ShardUploadWorker when WorkManager promotes them
    to expedited / foreground status (see ADR-007 + v1.0.1 s24 "expedited shard
    workers"). Kept deliberately generic: never includes album names, photo
    identifiers, file paths, or any user-identifying material.
  -->
  <string name="shard_upload_notification_channel_name">Mosaic album upload</string>
  <string name="shard_upload_notification_text">Uploading album to the cloud</string>
