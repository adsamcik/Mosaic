{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Default": "Data Source=./data/mosaic.db"
  },
  "Storage": {
    "Path": "./data/blobs"
  },
  "Auth": {
    "Mode": "LocalAuth",
    "TrustedProxies": ["127.0.0.1/32", "::1/128"],
    "ServerSecret": "dev-secret-do-not-use-in-production"
  },
  "Quota": {
    "DefaultMaxBytes": 10737418240
  }
}
