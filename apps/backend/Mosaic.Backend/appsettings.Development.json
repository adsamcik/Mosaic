{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Mosaic.Backend": "Debug"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "IncludeScopes": true,
        "TimestampFormat": "HH:mm:ss.fff ",
        "SingleLine": false,
        "ColorBehavior": "Enabled"
      }
    }
  },
  "ConnectionStrings": {
    "Default": "Data Source=./data/mosaic.db"
  },
  "Storage": {
    "Path": "./data/blobs"
  },
  "Auth": {
    "Mode": "LocalAuth",
    "TrustedProxies": ["127.0.0.1/32", "::1/128"],
    "ServerSecret": null
  },
  "Quota": {
    "DefaultMaxBytes": 10737418240
  }
}
