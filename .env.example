# =============================================================================
# Mosaic Environment Configuration
# =============================================================================
#
# Copy this file to .env and configure the values for your deployment.
#
# Quick start:
#   cp .env.example .env
#   openssl rand -base64 32  # Generate AUTH_SERVER_SECRET
#   openssl rand -base64 32  # Generate POSTGRES_PASSWORD
#   # Edit .env and set AUTH_SERVER_SECRET and POSTGRES_PASSWORD
#   docker compose up -d
#
# =============================================================================

# =============================================================================
# REQUIRED SETTINGS
# =============================================================================

# =============================================================
# AUTH CONFIGURATION (REQUIRED OUTSIDE DEVELOPMENT)
# =============================================================
#
# AUTH_SERVER_SECRET is used to derive deterministic fake-salt values
# for unknown usernames during LocalAuth init, preventing user
# enumeration via timing or salt-stability differences.
#
# Generate a stable 32-byte secret ONCE per deployment:
#   openssl rand -base64 32
#
# Once set, do NOT change it — doing so will cause already-registered
# users to see their auth init responses change and may break their
# password-managers' stored derivations. Rotate ONLY in a coordinated
# password-rotation event.
#
AUTH_SERVER_SECRET=

# PostgreSQL password - REQUIRED, docker-compose will fail if not set
# Generate a secure password: openssl rand -base64 32
POSTGRES_PASSWORD=

# =============================================================================
# NETWORK SETTINGS
# =============================================================================

# Port the frontend will be exposed on (default: 8080)
# Access the application at http://localhost:${FRONTEND_PORT}
FRONTEND_PORT=8080

# Your domain name (used for production deployments with reverse proxy)
# DOMAIN=photos.example.com

# Email for Let's Encrypt certificates (required if using auto-TLS)
# ACME_EMAIL=admin@example.com

# -----------------------------------------------------------------------------
# AllowedHosts — REQUIRED when deploying behind a custom domain
# -----------------------------------------------------------------------------
#
# appsettings.Production.json ships with AllowedHosts=localhost so that the
# default docker compose stack (browser → localhost:8080 → nginx → backend)
# works out of the box. nginx forwards the inbound Host header verbatim
# (`proxy_set_header Host $host`), so if your operator-facing reverse proxy
# (Traefik, Caddy, Authelia, nginx in front of compose, etc.) terminates a
# different hostname, EVERY API call will return HTTP 400 "BadHost" until you
# override AllowedHosts with your real domain(s).
#
# Set this to a semicolon-separated list of hostnames you actually serve from:
#   AllowedHosts=photos.example.com;photos.internal
# Or accept any host (NOT recommended for production):
#   AllowedHosts=*
#
# AllowedHosts=photos.example.com

# =============================================================================
# STORAGE SETTINGS
# =============================================================================

# Default storage quota per user in bytes
# 10 GB = 10737418240 (default)
# 50 GB = 53687091200
# 100 GB = 107374182400
DEFAULT_QUOTA_BYTES=10737418240

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Default docker compose deployments use local username/password authentication:
#   LOCAL_AUTH_ENABLED=true
#   PROXY_AUTH_ENABLED=false
#
# To use trusted reverse-proxy auth instead, configure your proxy to set
# the Remote-User header, then flip to proxy-auth-only:
#   LOCAL_AUTH_ENABLED=false
#   PROXY_AUTH_ENABLED=true
#
# Trusted proxy CIDR ranges (comma-separated for multiple)
# Docker internal networks are trusted by default in docker-compose.yml
#
# Examples:
#   Single IP:     AUTH_TRUSTED_PROXIES=192.168.1.100/32
#   Network:       AUTH_TRUSTED_PROXIES=10.0.0.0/8
#   Multiple:      Set multiple Auth__TrustedProxies__N in docker-compose.yml

# =============================================================================
# ADVANCED SETTINGS (rarely need to change)
# =============================================================================

# Database name (default: mosaic)
# POSTGRES_DB=mosaic

# Database user (default: mosaic)
# POSTGRES_USER=mosaic

# ASP.NET environment (Production, Development, Testing)
# ASPNETCORE_ENVIRONMENT=Production
