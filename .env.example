# Mosaic Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# PRODUCTION SETTINGS
# =============================================================================

# Domain for the application
DOMAIN=photos.example.com

# Email for Let's Encrypt certificates
ACME_EMAIL=admin@example.com

# =============================================================================
# DOCKER DEPLOYMENT
# =============================================================================

# PostgreSQL password (REQUIRED - generate with: openssl rand -base64 32)
POSTGRES_PASSWORD=changeme

# Frontend exposed port
FRONTEND_PORT=8080

# Default storage quota per user in bytes (10 GB)
DEFAULT_QUOTA_BYTES=10737418240

# =============================================================================
# LEGACY / ADVANCED SETTINGS
# =============================================================================

# Database password (generate with: openssl rand -base64 32)
DB_PASSWORD=

# Trusted proxy CIDR for authentication headers
# Default Docker network range
AUTH_TRUSTED_PROXIES=172.16.0.0/12

# Storage path for blob data
STORAGE_PATH=/data/blobs

# Maximum storage per user in bytes (default: 10GB)
MAX_STORAGE_BYTES=10737418240
